<div class="ccs-stunt">
  <div><b>{{localize "CCS.UI.Target"}}</b> {{targetName}}</div>
  <div class="form-group">
    <label>{{localize "CCS.UI.Plausible"}}</label>
    <input type="checkbox" name="plausible" checked/>
  </div>

  <hr/>
  <div class="form-group">
    <label>{{localize "CCS.UI.Flavor"}}</label>
    <select name="cool">
      <option value="none">{{localize "CCS.UI.FlavorNormal"}}</option>
      <option value="light">{{localize "CCS.UI.FlavorNice"}}</option>
      <option value="full">{{localize "CCS.UI.FlavorSoCool"}}</option>
    </select>
  </div>
  {{#if isPF2}}
    <div class="form-group" id="ccs-adv-row" style="display:none;">
      <label title="{{localize "CCS.UI.AdvantageTooltip"}}">
        <input type="checkbox" name="advNow"/>
        {{localize "CCS.UI.UseAdvantage"}}
      </label>
    </div>
  {{/if}}

  <hr/>
  <div class="form-group">
    <label title="{{localize "CCS.UI.TacticalRiskTooltip"}}">
      <input type="checkbox" name="risk"/> {{localize "CCS.UI.TacticalRisk"}}
    </label>
  </div>

  {{#if poolEnabled}}
  <hr/>
  <div class="form-group">
    <label><input type="checkbox" name="spendPool" {{#if poolRemaining}}{{else}}disabled{{/if}}/> {{localize "CCS.UI.SpendCinematicPool"}}</label>
  </div>
  {{/if}}

  {{#unless hideRollSource}}
    <div class="form-group">
      <label>{{localize "CCS.UI.RollSource"}}</label>
      <select name="rollKind">
        {{#each rollSources}}
          <option value="{{this.value}}">{{this.label}}</option>
        {{/each}}
      </select>
    </div>
  {{else}}
    <input type="hidden" name="rollKind" value="{{effectiveRollKind}}"/>
  {{/unless}}

  <div class="form-group ccs-row-skill">
    <label>{{localize "CCS.UI.Skill"}}</label>
    <select name="rollKey">
      {{#each skills}}
        <option value="{{this.value}}">{{this.label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group ccs-row-attack" style="display:none">
    <label>{{localize "CCS.UI.Strike"}}</label>
    <select name="strikeKey">
      {{#each strikes}}
        <option value="{{this.value}}">{{this.label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>{{localize "CCS.UI.Challenge"}}</label>
    <select name="challengeAdj">
      <option value="4">{{localize "CCS.UI.ChallengeMajorWeakness"}}</option>
      <option value="2">{{localize "CCS.UI.ChallengeWeakness"}}</option>
      <option value="0" selected>{{localize "CCS.UI.ChallengeNormal"}}</option>
      <option value="-2">{{localize "CCS.UI.ChallengeResistance"}}</option>
      <option value="-4">{{localize "CCS.UI.ChallengeMajorResistance"}}</option>
    </select>
  </div>

</div>